{
  "manifest_version": 3,
  "name": "Rabbit Wallet - Multi-Chain Crypto Wallet",
  "version": "1.0.0",
  "description": "Secure multi-chain crypto wallet with built-in key management",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage",
    "scripting",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "http://localhost/*",
    "https://*.infura.io/*",
    "https://*.alchemyapi.io/*",
    "https://*.etherscan.io/*",
    "https://cdn.ethers.io/*"
  ],
  "action": {
    "default_title": "Open ETH Wallet"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}